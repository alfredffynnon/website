---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Tagline alternatives — swap freely:
// "Applied mathematics at Harvard. Game theory, geopolitics, and the politics of technology."
// "Studying applied mathematics at Harvard; writing about strategy, states, and machines."
const tagline = 'Applied mathematics student at Harvard, writing on game theory and geopolitics.';
---
<Base
  title="Alfred Williamson — Writing on Game Theory and Geopolitics"
  description="Alfred Williamson is an applied mathematics student at Harvard College writing on game theory, geopolitics, and the politics of technology."
  current="home"
>
  <h1 class="home-name">Alfred Williamson</h1>
  <p class="tagline">{tagline}</p>
  <p>
    I study applied mathematics at Harvard College and write about how game theory
    explains, and fails to explain, the behaviour of states. I have spoken publicly
    on the position of international students in the United States, including in
    profiles by
    <a href="https://www.nytimes.com/2025/06/07/us/trump-harvard-international-student-ban.html">the New York Times</a>,
    <a href="https://www.theguardian.com/us-news/2025/may/30/welsh-first-year-at-harvard-fears-trump-ban-will-stop-him-finishing-degree">the Guardian</a>,
    and <a href="https://www.reuters.com/world/us/welsh-harvard-student-caught-up-trump-row-fears-he-may-never-return-2025-05-28/">Reuters</a>,
    and on <a href="https://www.cnn.com/2025/05/30/us/video/harvard-international-students-visa-trump-digvid">CNN</a>
    and <a href="https://www.npr.org/2025/06/16/nx-s1-5432750/harvard-lawsuit-international-students-hearing">NPR</a>.
  </p>

  <div class="section-head">
    <span class="meta">Recent writing</span>
  </div>
  <ul class="essay-list">
    {essays.map((e) => (
      <li>
        <a class="title" href={`/writing/${e.id}/`}>{e.data.title}</a>
        <span class="date">{fmt(e.data.date)}</span>
      </li>
    ))}
  </ul>
  <p style="margin-top: 1.2rem;"><a href="/writing/">All writing →</a></p>
</Base>
