---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base
  title="Writing | Alfred Williamson"
  description="Essays by Alfred Williamson on game theory, geopolitics, and the politics of technology."
  current="writing"
>
  <h1>Writing</h1>
  <ul class="essay-list">
    {essays.map((e) => (
      <li>
        <a href={`/writing/${e.id}/`}>{e.data.title}</a>
        <span class="date">{fmt(e.data.date)}</span>
        <p class="desc">{e.data.description}</p>
      </li>
    ))}
  </ul>
</Base>
