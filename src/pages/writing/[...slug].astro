---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('writing', ({ data }) => !data.draft);
  return essays.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const words = entry.body ? entry.body.split(/\s+/).length : 0;
const minutes = Math.max(1, Math.round(words / 220));

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  ...(entry.data.updated ? { dateModified: entry.data.updated.toISOString() } : {}),
  author: { '@type': 'Person', '@id': 'https://alfredwilliamson.com/about#person', name: 'Alfred Williamson' }
});
---
<Base title={`${entry.data.title} | Alfred Williamson`} description={entry.data.description} ogType="article" current="writing" progress={true}>
  <article class="prose">
    <h1>{entry.data.title}</h1>
    <p class="dek">{entry.data.description}</p>
    <p class="essay-meta">
      Essay · {fmt(entry.data.date)} · {minutes} min
      {entry.data.updated && ` · updated ${fmt(entry.data.updated)}`}
    </p>
    <Content />
  </article>
  <script type="application/ld+json" set:html={jsonLd} />
</Base>
